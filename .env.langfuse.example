# Secrets for the `langfuse` Compose project. Copy to `.env.langfuse` and fill in.
#   cp .env.langfuse.example .env.langfuse
# Bring up with:
#   docker compose --env-file .env.langfuse -f docker-compose.langfuse.yml up -d

# URL users load the Langfuse UI from (must match the origin in the browser, or
# login breaks). Tailscale host on port 3001 by default.
NEXTAUTH_URL=http://YOUR-HOST:3001

# --- Core secrets ---
# ENCRYPTION_KEY: openssl rand -hex 32
# SALT / NEXTAUTH_SECRET: openssl rand -base64 32
ENCRYPTION_KEY=CHANGEME-64-hex-chars
SALT=CHANGEME
NEXTAUTH_SECRET=CHANGEME

# --- Backing stores (internal to the Langfuse stack) ---
# Generate each: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres   # password must match POSTGRES_PASSWORD
CLICKHOUSE_PASSWORD=CHANGEME
REDIS_AUTH=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME   # = MINIO_ROOT_PASSWORD
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME   # = MINIO_ROOT_PASSWORD

# --- Auto-provision org / project / admin user + API keys on first boot ---
# The PUBLIC/SECRET keys here are what LiteLLM uses (mirror them in .env).
# Generate ids: uuidgen ; keys conventionally pk-lf-<uuid> / sk-lf-<uuid>.
LANGFUSE_INIT_ORG_ID=CHANGEME-uuid
LANGFUSE_INIT_ORG_NAME=YourOrg
LANGFUSE_INIT_PROJECT_ID=CHANGEME-uuid
LANGFUSE_INIT_PROJECT_NAME=classroom
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGEME
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_NAME=Your Name
LANGFUSE_INIT_USER_PASSWORD=CHANGEME
