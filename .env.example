# Secrets for the `vllm` Compose project. Copy to `.env` and fill in.
#   cp .env.example .env

# Master key for LiteLLM admin/proxy. Generate: openssl rand -hex 24
LITELLM_MASTER_KEY=sk-master-CHANGEME

# Hugging Face token (for gated/private model downloads); leave blank if unused.
HF_TOKEN=

# LiteLLM's internal Postgres role password. Generate: openssl rand -hex 24
LITELLM_PG_PASSWORD=CHANGEME

# LiteLLM -> Langfuse project keys.
# These MUST match LANGFUSE_INIT_PROJECT_PUBLIC_KEY / _SECRET_KEY in .env.langfuse.
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME
